---
import { projects } from "../../utils/info";
import ProjectCard from "./ProjectCard.astro";
---
<section class="flex flex-col gap-4 justify-center min-h-screen py-20" id="projects">
    <h2 class="font-medium animate-appear">Proyectos</h2>
    <div class="grid grid-cols-1 gap-4 justify-between max-lg:grid-cols-1">
        {projects.map((project) => <ProjectCard {...project} />)}
    </div>
</section>

<style>
    div > article {
        animation-range: entry 5% cover 20%;
    }

    @media (max-width: 767px) {
    div > article {
      animation-range: entry 5% cover 5%;
    }
  }
</style>