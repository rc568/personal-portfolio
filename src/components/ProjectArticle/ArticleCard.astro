---
import type { Article } from "../../interfaces/index";
import { lineBreakFormatter } from "../../utils/formatter";

type Props = Article;

const { title, dateRange, place, description } = Astro.props;
---

<article class="flex w-full flex-col gap-1 py-4">
    <div class="flex flex-col items-start justify-between gap-2 lg:flex-row">
        <h3
            class="text-foreground/90 max-w-full tracking-tight uppercase lg:max-w-prose"
        >
            {title}
        </h3>

        <span class="text-foreground/65 shrink-0 text-sm lg:self-end">
            {dateRange}
        </span>
    </div>

    <p class="text-accent-text italic">
        {place}
    </p>

    {
        description && (
            <p
                class="text-foreground/80 mt-2"
                set:html={lineBreakFormatter(description)}
            />
        )
    }
</article>
