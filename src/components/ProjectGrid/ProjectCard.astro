---
import Redirect from "@icons/redirect.svg?raw";
import { Image } from "astro:assets";
import type { Project } from "../../interfaces";
import { lineBreakFormatter } from "../../utils/formatter";
import Chip from "../Common/Chip.astro";

type Props = Project;

const {
    title,
    description,
    technologies,
    show = true,
    href,
    urlImage
} = Astro.props;
---

{
    show && (
        <article class="animate-appear flex flex-col overflow-clip rounded-3xl bg-gradient-to-r from-cyan-600 via-85% to-green-300 shadow-md backdrop-blur-md transition-all delay-75 duration-500 hover:shadow-lg">
            <div class="overflow-hidden">
                <Image
                    class="aspect-video w-full object-cover object-left-top transition-transform duration-500 hover:scale-105"
                    src={urlImage}
                    alt={`foto portada de ${title}`}
                    width="880"
                    height="495"
                />
            </div>
            <div class="m-4 flex grow flex-col justify-between gap-2 text-slate-700 lg:px-6">
                <div>
                    <div class="flex items-center justify-between">
                        <h3 class="font-bold">{title}</h3>
                        <a
                            class="w-7 transition-colors duration-300 hover:text-lime-700"
                            href={href}
                            target="_blank"
                            rel="noreferrer noopener"
                        >
                            <Fragment set:html={Redirect} />
                        </a>
                    </div>
                    <p
                        class="my-3 text-sm leading-relaxed"
                        set:html={lineBreakFormatter(description)}
                    />
                </div>
                <div>
                    <span class="text-sm font-semibold">Tecnologías:</span>
                    <div
                        id="stack-container"
                        class="flex gap-2 overflow-x-auto pt-2 whitespace-nowrap lg:flex-wrap lg:overflow-x-visible"
                    >
                        {technologies.map((tech) => (
                            <Chip text={tech} />
                        ))}
                    </div>
                </div>
            </div>
        </article>
    )
}

<style>
    #stack-container {
        scrollbar-width: none;
        -ms-overflow-style: none;
    }

    #stack-container::-webkit-scrollbar {
        display: none;
    }
</style>
