---
import Email from "@icons/email.svg?raw";
import Github from "@icons/github.svg?raw";
import Linkedin from "@icons/linkedin.svg?raw";
import Whatsapp from "@icons/whatsapp.svg?raw";
---

<div id="contact">
    <h2 class="pb-6">Contacto</h2>
    <div class="flex gap-12 items-center mx-auto w-fit pb-6">
        <a class="w-8 lg:w-10 hover:text-teal-800 transition-colors delay-75" href="mailto:isaac568r@gmail.com" target="_blank" rel="noreferrer noopener">
            <Fragment set:html={Email} />
        </a>
        <a class="w-6 lg:w-8 hover:text-teal-800 transition-colors delay-75" href="https://api.whatsapp.com/send/?phone=51993804361&text&type=phone_number&app_absent=0" target="_blank" rel="noreferrer noopener">
            <Fragment set:html={Whatsapp} />
        </a>
        <a class="w-6 lg:w-8 hover:text-teal-800 transition-colors delay-75" href="https://github.com/rc568" target="_blank" rel="noreferrer noopener">
            <Fragment set:html={Github} />
        </a>
        <a class="w-6 lg:w-8 hover:text-teal-800 transition-colors delay-75" href="https://www.linkedin.com/in/rojasisaac/" target="_blank" rel="noreferrer noopener">
            <Fragment set:html={Linkedin} />
        </a>
    </div>
</div>
