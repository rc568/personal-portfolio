---
import { technologies } from "../../utils/info";
import Chip from "../Common/Chip.astro";
---

<section class="flex flex-col gap-4 py-6">
    <h2>Tecnologías</h2>
    {
        technologies.map((technology) => {
            return (
                technology.show && (
                    <section>
                        <h3 class="pb-2">{technology.title}</h3>
                        <div class="flex flex-wrap gap-3">
                            {technology.technologies.map((tech) => (
                                <Chip text={tech} />
                            ))}
                        </div>
                    </section>
                )
            );
        })
    }
</section>
